{
  "name": "ai-office2",
  "version": "2.0.0",
  "description": "AI 오피스2 - Slack-style AI Agent Team Platform",
  "author": "AI 오피스2",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "agent:start": "tsx agent-core/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.103.2",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "gray-matter": "^4.0.3",
    "openai": "^6.37.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.7",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.aioffice2.app",
    "productName": "AI 오피스2",
    "copyright": "Copyright © 2026 AI 오피스2",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "agent-core/**/*",
      "vault/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
