{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "types": ["vite/client"]
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/index.css",
    "src/types/**/*",
    "src/data/**/*",
    "src/utils/**/*",
    "src/contexts/**/*",
    "src/components/**/*"
  ],
  "exclude": ["node_modules", "dist", "agent-core", "electron"]
}
